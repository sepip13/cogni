generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  image     String?
  password  String?   @db.Text
  emailVerified        DateTime?
  plan                 UserPlan  @default(FREE)
  preferredLanguage    String?
  preferredQualityTier String?   @default("balanced")
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  proAccessEndsAt      DateTime?
  createdAt            DateTime  @default(now())
  accounts    Account[]
  sessions    Session[]
  courses     Course[]
  redemptions AccessCodeRedemption[]
}

enum UserPlan {
  FREE
  PRO
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Course {
  id                   String        @id @default(cuid())
  userId               String
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  code                 String?
  educationLevel       String?
  examDate             DateTime?
  status               CourseStatus  @default(PROCESSING)
  rawText              String?       @db.Text
  plan                 Json?
  totalPrepTimeMinutes Int?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  files                SourceFile[]
  topics               Topic[]
  chatMessages         ChatMessage[]
  shares               CourseShare[]
  submissions          Submission[]
}

enum CourseStatus {
  PROCESSING
  READY
  FAILED
}

model SourceFile {
  id         String  @id @default(cuid())
  courseId   String
  course     Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  fileName   String
  fileType   String
  blobUrl    String
  parsedText String? @db.Text
  pageCount  Int?
}

model Topic {
  id                String    @id @default(cuid())
  courseId          String
  course            Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  num               String
  title             String
  priority          Priority
  priorityLabel     String?
  why               String    @db.Text
  timeMinutes       Int
  pages             String?
  studied           Boolean   @default(false)
  studiedAt         DateTime?
  subtopics         Json
  practiceQuestions Json
  sources           Json
  order             Int
}

enum Priority {
  HIGH
  MED
  LOW
}

model ChatMessage {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())
}

model AccessCode {
  id            String                 @id @default(cuid())
  code          String                 @unique
  durationDays  Int
  maxUses       Int                    @default(1)
  usedCount     Int                    @default(0)
  codeExpiresAt DateTime?
  isActive      Boolean                @default(true)
  note          String?
  createdBy     String
  createdAt     DateTime               @default(now())
  redemptions   AccessCodeRedemption[]
}

model AccessCodeRedemption {
  id           String     @id @default(cuid())
  codeId       String
  code         AccessCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  redeemedAt   DateTime   @default(now())
  accessEndsAt DateTime

  @@unique([codeId, userId])
}

model PracticeAttempt {
  id            String   @id @default(cuid())
  topicId       String
  userId        String
  questionIndex Int
  userAnswer    String   @db.Text
  score         Int
  verdict       String
  feedback      String   @db.Text
  createdAt     DateTime @default(now())
}

model LlmModel {
  id        String    @id @default(cuid())
  modelId   String    @unique
  label     String
  desc      String
  bestFor   String    @default("")
  category  String    @default("General")
  provider  String
  tier      ModelTier @default(FREE)
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum ModelTier {
  FREE
  PRO
}

// ── Sharing ────────────────────────────────────────────────
model CourseShare {
  id           String          @id @default(cuid())
  courseId     String
  course       Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  token        String          @unique // unguessable, URL-safe, >= 24 chars
  permission   SharePermission @default(VIEW)
  publicNoAuth Boolean         @default(true) // true = anyone with the link, no sign-in
  includeSources Boolean       @default(false) // owner opt-in to expose source files
  revoked      Boolean         @default(false)
  expiresAt    DateTime?
  createdBy    String
  createdAt    DateTime        @default(now())
  viewCount    Int             @default(0)

  @@index([courseId])
}

enum SharePermission {
  VIEW // read-only: study plan + topics (+ sources if owner opted in)
  COMMENT // VIEW + can leave comments (requires sign-in)
}

// ── Student work (distinct from SourceFile course material) ──
model Submission {
  id         String             @id @default(cuid())
  courseId   String
  course     Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId     String
  title      String
  kind       SubmissionKind     @default(ASSIGNMENT)
  status     SubmissionStatus   @default(IN_PROGRESS)
  fileName   String?
  fileType   String?
  blobUrl    String?
  parsedText String?            @db.Text
  pageCount  Int?
  questions  Json? // cached personalized examiner questions
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  reviews    SubmissionReview[]

  @@index([courseId])
  @@index([userId])
}

enum SubmissionKind {
  ASSIGNMENT
  PROJECT
  PORTFOLIO
  ESSAY
  REPORT
  OTHER
}

enum SubmissionStatus {
  IN_PROGRESS
  READY_FOR_REVIEW
  REVIEWED
}

// ── Rubric-based review snapshots (track improvement over time) ──
model SubmissionReview {
  id              String     @id @default(cuid())
  submissionId    String
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  scoreOutOf10    Float // 0.0 – 10.0
  rubricBreakdown Json // [{ criterion, scored, max, comment }]
  strengths       Json // string[]
  gaps            Json // string[]  — what's missing for 10/10
  actionItems     Json // string[]  — concrete steps to complete
  summary         String     @db.Text
  modelId         String
  createdAt       DateTime   @default(now())

  @@index([submissionId])
}
