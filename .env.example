# ── Database ──────────────────────────────────────────────────────────────────
# Neon, Supabase, or Vercel Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Needed if you use a connection pooler (PgBouncer) — use the direct URL here
# DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Auth (NextAuth v5) ────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=

# Public URL of this app — set automatically on Vercel; required for local dev
AUTH_URL=http://localhost:3000

# ── OAuth providers ───────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# https://resend.com/api-keys
# Verify your "from" domain at resend.com/domains
RESEND_API_KEY=

# ── AI ────────────────────────────────────────────────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Vercel Blob Storage ───────────────────────────────────────────────────────
# Vercel dashboard → Storage → Blob → Create store → copy token
BLOB_READ_WRITE_TOKEN=
