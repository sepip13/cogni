# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Example: postgresql://cogni_user:password@localhost:5432/cogni_db
DATABASE_URL=postgresql://user:password@host/dbname

# ── Auth (NextAuth v5) ────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=

# Public URL of this app — required for production
# Example: https://cogni.futuresage.online
AUTH_URL=http://localhost:3000

# ── Email (Resend) ────────────────────────────────────────────────────────────
# https://resend.com/api-keys
# Verify your "from" domain at resend.com/domains
RESEND_API_KEY=

# ── FreeLLMAPI (sole LLM provider — aggregates Gemini, Groq, Mistral, …) ──────
# Run the freellmapi server (../freellmapi) and copy the unified key it prints.
# Required: this is the only LLM backend (no Anthropic/Claude dependency).
# FREELLMAPI_URL=http://localhost:3001
# FREELLMAPI_KEY=freellmapi-xxxxxxxxxxxxxxxxxxxx
# FREELLMAPI_MODEL=auto
# Model for PRO users on the work/exam features (strongest, large-context).
# Falls back to "gemini-3.5-flash" if unset.
# FREELLMAPI_PRO_MODEL=gemini-3.5-flash

# ── File Storage ──────────────────────────────────────────────────────────────
# Absolute path where uploaded course files are saved
# Defaults to ./uploads relative to the project root if not set
# Example for VPS: /var/www/cogni/uploads
UPLOAD_DIR=
