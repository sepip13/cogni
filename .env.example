# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Example: postgresql://cogni_user:password@localhost:5432/cogni_db
DATABASE_URL=postgresql://user:password@host/dbname

# ── Auth (NextAuth v5) ────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=

# Public URL of this app — required for production
# Example: https://cogni.futuresage.online
AUTH_URL=http://localhost:3000

# ── Email (Resend) ────────────────────────────────────────────────────────────
# https://resend.com/api-keys
# Verify your "from" domain at resend.com/domains
RESEND_API_KEY=

# ── FreeLLMAPI (sole LLM provider — aggregates Gemini, Groq, Mistral, …) ──────
# Run the freellmapi server (../freellmapi) and copy the unified key it prints.
# Required: this is the only LLM backend (no Anthropic/Claude dependency).
# FREELLMAPI_URL=http://localhost:3001
# FREELLMAPI_KEY=freellmapi-xxxxxxxxxxxxxxxxxxxx
# FREELLMAPI_MODEL=auto
# Model for PRO users on the work/exam features (strongest, large-context).
# Falls back to "gemini-3.5-flash" if unset.
# FREELLMAPI_PRO_MODEL=gemini-3.5-flash

# ── File Storage ──────────────────────────────────────────────────────────────
# Absolute path where uploaded course files are saved
# Defaults to ./uploads relative to the project root if not set
# Example for VPS: /var/www/cogni/uploads
UPLOAD_DIR=

# ── Feedback / interview survey pop-up ────────────────────────────────────────
# The Google Form people are invited to fill in. The pop-up is OFF until this is
# set. NEXT_PUBLIC_* is inlined at build time — rebuild after changing it.
NEXT_PUBLIC_FEEDBACK_FORM_URL=https://docs.google.com/forms/d/e/XXXXXXXX/viewform
# Set to "false" to hard-disable the pop-up without removing the URL.
NEXT_PUBLIC_FEEDBACK_SURVEY_ENABLED=true
# Optional: auto-tag responses with where they came from. Add a short-answer
# question (e.g. "Source") to the form, then ⋮ → "Get pre-filled link", type any
# value, copy the link, and paste ONLY the entry id here (the entry.123456789
# part). The app fills it with "Cogni app" / "Cogni landing page" automatically.
NEXT_PUBLIC_FEEDBACK_FORM_SOURCE_ENTRY=
